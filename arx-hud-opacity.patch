# FILE 4: src/gui/Hud.cpp  (17 hunks)
#
# Hunk 1  — hudAlpha() file-local helper: scales vertex alpha by hud_opacity.
#
# ** THE CRITICAL FIX — WHY VERTEX ALPHA ALONE DOES NOTHING **
# Arx's GL texture stage defaults to GL_COMBINE_ALPHA = GL_REPLACE, meaning
# fragment_alpha = texture_alpha, ignoring vertex alpha entirely (there is a
# TODO comment about this in GLTextureStage.cpp). Without the OpModulate
# bracket below, hudAlpha() would have zero visual effect.
#
# Hunk 16 — setAlphaOp(OpModulate) at the start of HudRoot::draw() draw block.
#            Switches formula to: fragment_alpha = texture_alpha * vertex_alpha.
#            With vertex_alpha = hud_opacity * 255, result = texture_alpha * hud_opacity.
# Hunk 17 — setAlphaOp(OpSelectArg1) at the very end of HudRoot::draw().
#            Restores the default so nothing outside the HUD is affected.
#
# Hunks 2-15 — hudAlpha() applied to every EERIEDrawBitmap color argument in
#              each HUD element's draw function. Works for both standard-blend
#              and additive-blend elements once OpModulate is active.
#              Exception: QuickSaveIconGui uses BlendSrcColor (screen blend),
#              where RGB is the blend factor — opacity applied to gray value directly.
# =============================================================================
--- a/gui/Hud.cpp
+++ b/gui/Hud.cpp
@@ -68,6 +68,11 @@
 static const int indicatorVertSpacing = 30;
 static const int indicatorHorizSpacing = 20;
 
+// Scale vertex alpha by HUD opacity. Works for all blend modes once OpModulate is active.
+static Color hudAlpha(Color c) {
+	return Color(c.r, c.g, c.b, u8(float(c.a) * config.interface.hudOpacity));
+}
